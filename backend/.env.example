# Expenso Backend — Environment Variables
# Copy to .env and fill in the values

APP_NAME=Expenso
APP_ENV=development
DEBUG=true

# Security
SECRET_KEY=generate-a-secure-random-key-here
ALLOWED_ORIGINS=http://localhost:5173

# Database
DATABASE_URL=postgresql://expenso:expenso@localhost:5432/expenso_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=expenso-files
MINIO_SECURE=false

# JWT
JWT_SECRET_KEY=generate-a-secure-random-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Payment Gateway
PAYMENT_GATEWAY=mock
REVOLUT_API_KEY=
REVOLUT_API_URL=https://sandbox-b2b.revolut.com/api/1.0
REVOLUT_CLIENT_ID=
REVOLUT_PRIVATE_KEY=
REVOLUT_WEBHOOK_SECRET=
PAYMENT_MAX_RETRIES=3
PAYMENT_RETRY_DELAY_MINUTES=15
