# ═══════════════════════════════════════════════════════════════
# Expenso v1.0.0 — Production Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file and fill in all values marked with [MANUAL]
# Variables marked [AUTO] can be generated with the commands shown
# Variables marked [RENDER] are provided by Render automatically
# ═══════════════════════════════════════════════════════════════

# ─── APP ─────────────────────────────────────────────────────
APP_NAME=Expenso
APP_ENV=production
DEBUG=false

# [AUTO] python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# [AUTO] python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://app.expenso.io

# Frontend URL for email links (password reset, notifications)
FRONTEND_URL=https://app.expenso.io

# ─── DATABASE ────────────────────────────────────────────────
# [RENDER] Provided by Render PostgreSQL service automatically
DATABASE_URL=

# ─── REDIS ───────────────────────────────────────────────────
# [RENDER] Provided by Render Redis service automatically
REDIS_URL=

# ─── CELERY ──────────────────────────────────────────────────
# Uses same Redis instance, different databases
# [RENDER] Derived from REDIS_URL
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ─── JWT ─────────────────────────────────────────────────────
# [AUTO] python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── STORAGE (MinIO / S3) ───────────────────────────────────
# [MANUAL] S3-compatible storage for file attachments
MINIO_ENDPOINT=s3.amazonaws.com
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=expenso-files
MINIO_SECURE=true

# ─── ANTHROPIC (AI Engine) ──────────────────────────────────
# [MANUAL] https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── REVOLUT (Payment Gateway) ──────────────────────────────
# [MANUAL] https://business.revolut.com → API Settings
PAYMENT_GATEWAY=revolut
REVOLUT_API_URL=https://b2b.revolut.com/api/1.0
REVOLUT_API_KEY=
REVOLUT_CLIENT_ID=
# RSA private key in PEM format, newlines escaped as \n
REVOLUT_PRIVATE_KEY=
# HMAC secret for webhook signature validation
REVOLUT_WEBHOOK_SECRET=
PAYMENT_MAX_RETRIES=3
PAYMENT_RETRY_DELAY_MINUTES=15

# ─── EMAIL (SMTP) ───────────────────────────────────────────
# [MANUAL] SMTP provider credentials (SendGrid, SES, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@expenso.io

# ─── SSO — Google Workspace (Optional) ─────────────────────
# [MANUAL] https://console.cloud.google.com → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── SSO — Azure AD (Optional) ─────────────────────────────
# [MANUAL] https://portal.azure.com → App Registrations
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# ─── RATE LIMITING ──────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# ─── PASSWORD RESET ─────────────────────────────────────────
PASSWORD_RESET_EXPIRE_HOURS=2
